# ---- App ----
APP_NAME=PayGuard
ENV=dev
API_PREFIX=/api
SECRET_KEY=change-me-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000

# ---- Database ----
DATABASE_URL=postgresql+psycopg2://payguard:payguard@postgres:5432/payguard

# ---- Redis / jobs ----
REDIS_URL=redis://redis:6379/0
USE_BACKGROUND_JOBS=false

# ---- File storage ----
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./storage
PUBLIC_FILE_BASE_URL=http://localhost:8000/api/files
# S3 (prod)
S3_BUCKET=
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ---- Model inference ----
# heuristic | local_model | hybrid
INVOICE_EXTRACTION_MODE=hybrid
LOCAL_MODEL_DIR=/models/invoice_extractor

# ---- OCR ----
OCR_ENABLED=true
TESSERACT_CMD=
